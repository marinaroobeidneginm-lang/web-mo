PORT=3001

# ═══════════════════════════════════════════════════════════════
# COPIÁ ESTOS STRINGS DESDE SUPABASE DASHBOARD → Connect
# No uses db.xxx.supabase.co en Windows (solo IPv6, falla con P1001)
# ═══════════════════════════════════════════════════════════════

# Session pooler (puerto 5432) — para migraciones y app
# Agregar ?sslmode=require (y &sslmode=require si ya hay ?pgbouncer=true)
DIRECT_URL="PEGAR_AQUI_SESSION_POOLER_STRING?sslmode=require"
DATABASE_URL="PEGAR_AQUI_SESSION_POOLER_STRING?pgbouncer=true&sslmode=require"

# Para Vercel (serverless), usá además Transaction pooler (6543) con ?pgbouncer=true
# DATABASE_URL="PEGAR_TRANSACTION_POOLER_6543?pgbouncer=true"

JWT_SECRET=cambiar-por-secreto-largo
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@marinaroobeid.com
ADMIN_PASSWORD_HASH="PEGAR_HASH_BCRYPT"

# Supabase Storage (Dashboard → Project Settings → API)
SUPABASE_URL="https://TU-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="PEGAR_SERVICE_ROLE_SECRET"
SUPABASE_STORAGE_BUCKET=propiedades
